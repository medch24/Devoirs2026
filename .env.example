# MongoDB Configuration
# ⚠️ IMPORTANT: Set this in Vercel/Cloudflare Environment Variables
MONGODB_URI=mongodb+srv://cherifmed2010:Mmedch86@devoirs.m5p4c1w.mongodb.net/?appName=devoirs

# Alternative variable names (if MONGODB_URI doesn't work, try these)
# MONGODB_ATLAS_URI=mongodb+srv://...
# MONGODB_URL=mongodb+srv://...
# MONGO_URI=mongodb+srv://...
# MONGODB_REAL_URI=mongodb+srv://...
# MONGODB_TEST_URI=mongodb+srv://...

# Database name (optional, will be extracted from URI)
